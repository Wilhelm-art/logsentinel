# ─────────────────────────────────────────────
# LogSentinel Environment Configuration
# Copy to .env and fill in your values
# ─────────────────────────────────────────────

# ── Authentication (NextAuth v5) ──
AUTH_SECRET=           # Generate with: npx auth secret
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
ALLOWED_EMAILS=admin@example.com

# ── Database ──
POSTGRES_USER=logsentinel
POSTGRES_PASSWORD=changeme_strong_password_here
POSTGRES_DB=logsentinel
DATABASE_URL=postgresql+asyncpg://logsentinel:changeme_strong_password_here@postgres:5432/logsentinel

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── LLM Provider ──
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GROQ_API_KEY=

# ── Threat Intelligence ──
ABUSEIPDB_API_KEY=
ABUSEIPDB_ENABLED=true

# ── Application ──
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXTAUTH_URL=http://localhost:3000
MAX_FILE_SIZE_MB=10
MAX_LOG_LINES=50000
SAMPLING_THRESHOLD=10000
